{
  "name": "@ckb/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsx watch --env-file=../../.env src/main.ts",
    "start": "node --env-file=../../.env dist/main.js",
    "db:migrate": "tsx --env-file=../../.env src/db/migrate.ts",
    "db:seed": "tsx --env-file=../../.env src/db/seed.ts"
  },
  "dependencies": {
    "@ckb/audit": "workspace:*",
    "@ckb/auth": "workspace:*",
    "@ckb/domain": "workspace:*",
    "@ckb/secrets": "workspace:*",
    "@ckb/shared": "workspace:*",
    "@nestjs/common": "^10.3.7",
    "@nestjs/core": "^10.3.7",
    "@nestjs/platform-express": "^10.3.7",
    "mssql": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/mssql": "^9.1.5",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.2",
    "rimraf": "^5.0.5",
    "supertest": "^7.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
