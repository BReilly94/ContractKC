{
  "name": "@ckb/outlook-addin",
  "version": "0.1.0",
  "private": true,
  "description": "Microsoft Outlook add-in that routes emails to Contract Knowledge Base project-designated addresses (SOW §6.18).",
  "scripts": {
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "build": "webpack --mode production",
    "dev": "webpack serve --mode development",
    "start": "office-addin-debugging start manifest.xml",
    "stop": "office-addin-debugging stop manifest.xml",
    "validate": "office-addin-manifest validate manifest.xml",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/office-js": "^1.0.377",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "copy-webpack-plugin": "^12.0.2",
    "html-webpack-plugin": "^5.6.0",
    "office-addin-debugging": "^5.0.13",
    "office-addin-manifest": "^1.13.1",
    "rimraf": "^5.0.5",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  }
}
